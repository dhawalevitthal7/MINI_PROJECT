CACHE_DB_URL=

# Google Gemini (SQLAI)
GEMINI_API_KEY=

# Optional: Azure OpenAI (SQLAI/config.py)
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_API_VERSION=2024-12-01-preview
DEPLOYMENT_NAME=gpt-4o

# Example for migrations / docs
MONGO_URL=
